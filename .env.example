# Профиль по умолчанию для гостей (без входа) — только /api/v1/auth/session
APP_PROFILE_ID=default

# true = mock-БД без Postgres (рекомендуется для локальной разработки)
USE_MOCK_DB=true

API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://pump:pump@localhost:5432/pumpstation

JWT_SECRET=change-me-in-production-dev-only
JWT_EXPIRE_MINUTES=480

VITE_API_BASE_URL=http://localhost:8000
