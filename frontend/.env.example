# SQLite (локальная БД API)
# USE_SQLITE=true
# SQLITE_PATH=./data/app.sqlite

# База для статики вне origin приложения (шрифты остаются в /public/fonts при сборке).
# Пример: VITE_STATIC_BASE_URL=http://159.194.215.53/pump-station-static
# VITE_STATIC_BASE_URL=

# Картинки карточек BPS-C: в dev по умолчанию Figma URL; для локальных PNG: VITE_HM_USE_FIGMA=0
# VITE_HM_USE_FIGMA=0
